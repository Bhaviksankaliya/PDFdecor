# ── API ──────────────────────────────────────────────
API_PORT=3001
WEB_ORIGIN=http://localhost:3000
STORAGE_DIR=./storage

# ── Web ──────────────────────────────────────────────
# Where the Next.js rewrite proxies /api/* to.
API_INTERNAL_URL=http://localhost:3001

# ── Phase 2+ (not required for the Phase 1 sync tools) ──
DATABASE_URL=postgresql://pdfforge:pdfforge@localhost:5432/pdfforge
REDIS_URL=redis://localhost:6379
# S3 / MinIO (prod storage driver)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=pdfforge
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ── Phase 4 (AI tools) ──────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
