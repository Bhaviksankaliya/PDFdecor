# PDFForge Next.js web image.
FROM node:22-bookworm-slim AS build
WORKDIR /app
COPY package*.json ./
COPY packages ./packages
COPY apps/web ./apps/web
RUN npm install
RUN npm run build -w @pdfforge/web

FROM node:22-bookworm-slim
WORKDIR /app
COPY --from=build /app ./
ENV NODE_ENV=production
EXPOSE 3000
CMD ["npm", "run", "start", "-w", "@pdfforge/web"]
